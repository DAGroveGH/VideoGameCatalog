@using VideoGameCatalog.Client.Services
@using VideoGameCatalog.Shared.Models
@using VideoGameCatalog.Client.Components.Dashboard
@page "/"

@inject IVideoGameApiService VideoGameApiService;
@inject VideoGameCSVApiService VideoGameCSVApiService

<PageTitle>Video Game Report</PageTitle>

<DashboardOverview Games="@_games" />

@code {
    private IReadOnlyList<VideoGameModel>? _games;
    private List<VideoGameModel> _filteredGames = new();

    protected override async Task OnInitializedAsync()
    {
        _games = await VideoGameCSVApiService.GetAllAsync();
    }

}